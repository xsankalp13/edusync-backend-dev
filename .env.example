# ================================================================
# .env.example — copy to .env on your EC2 instance and fill in
# the real values.  NEVER commit the real .env to git.
# ================================================================

# ── Spring ───────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Database (Azure PostgreSQL Flexible Server) ───────────────────
# Example: jdbc:postgresql://<server>.postgres.database.azure.com:5432/<db>?sslmode=require
DB_URL=jdbc:postgresql://<azure-host>:5432/<dbname>?sslmode=require
DB_USER=<azure-pg-user>
DB_PASS=<azure-pg-password>

# ── Redis Cloud (free tier) ───────────────────────────────────────
REDIS_HOST=redis-xxxxx.ec2.cloud.redislabs.com
REDIS_PORT=<redis-cloud-port>
REDIS_TIMEOUT=2s
REDIS_USERNAME=default
REDIS_PASSWORD=<redis-cloud-password>
REDIS_SSL_ENABLED=false

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=<minimum-32-char-random-string>
JWT_EXPIRATION_TIME=3600000
REFRESH_EXPIRATION_TIME=86400000
PASSWORD_RESET_TIME=900000

# ── Mail (SMTP) ───────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email@gmail.com>
MAIL_PASSWORD=<app-password>
MAIL_FROM=no-reply@shikshaintelligence.com

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=<rzp_live_...>
RAZORPAY_KEY_SECRET=<secret>

# ── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
CLOUDINARY_UPLOAD_FOLDER=profiles

# ── App ───────────────────────────────────────────────────────────
BASE_URL=https://<your-domain-or-ec2-ip>
API_VERSION=/api/v1
APP_FRONTEND_URL=https://<your-frontend-url>

# ── Misc ─────────────────────────────────────────────────────────
JASYPT_ENCRYPTOR_PASSWORD=<strong-random-password>
SNS_ENABLED=false
SUPER_ADMIN_BOOTSTRAP_REQUIRED=true
FLYWAY_BASELINE_ON_MIGRATE=false

# ── Docker image (injected automatically by CI; set manually for local prod) ──
IMAGE_NAME=ghcr.io/<your-github-org>/edusync-backend:latest



